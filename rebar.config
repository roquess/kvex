{erl_opts, [debug_info, warnings_as_errors]}.

{deps, []}.

{plugins, [rebar3_rustler]}.

{cargo_opts, [
    {src_dir, "native/kvex_nif"},
    {release, true}
]}.

{provider_hooks, [
    {pre, [
        {compile, {cargo, build}}
    ]},
    {post, [
        {clean, {cargo, clean}},
        {eunit, {cargo, test}}
    ]}
]}.

{ct_opts, []}.

{edoc_opts, [{preprocess, true}, {dir, "doc"}]}.

{profiles, [
    {test, [{erl_opts, [nowarn_export_all]}]}
]}.
